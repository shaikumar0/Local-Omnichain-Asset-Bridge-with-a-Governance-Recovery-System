# Private key for an account funded on both local chains (Hardhat default key)
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# RPC URLs for the relayer (when running outside docker-compose)
CHAIN_A_RPC_URL=http://127.0.0.1:8545
CHAIN_B_RPC_URL=http://127.0.0.1:9545

# Chain IDs
CHAIN_A_CHAIN_ID=1111
CHAIN_B_CHAIN_ID=2222

# Confirmation depth for the relayer
CONFIRMATION_DEPTH=3

# Relayer polling interval (ms)
RELAYER_POLL_INTERVAL_MS=2000

# Path for relayer persistence file
DB_PATH=./relayer/data/processed_nonces.json

# Optional relayer address override (defaults to deployer address if empty)
RELAYER_ADDRESS=

# Minimum votes required to pass governance proposals (in token wei)
MIN_VOTES=1000000000000000000

# Deployment metadata paths for relayer
CHAIN_A_DEPLOYMENT_PATH=./deployments/chain-a.json
CHAIN_B_DEPLOYMENT_PATH=./deployments/chain-b.json
